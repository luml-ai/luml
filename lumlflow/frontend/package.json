{
  "name": "lumlflow-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "style": "npx style-dictionary build --config style-dictionary.config.mjs"
  },
  "dependencies": {
    "@luml/attachments": "*",
    "@luml/experiments": "*",
    "@primeuix/themes": "^2.0.3",
    "@primevue/forms": "^4.3.9",
    "@tailwindcss/vite": "^4.1.18",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.13.5",
    "dompurify": "^3.3.3",
    "github-markdown-css": "^5.9.0",
    "lucide-vue-next": "^0.460.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "primevue": "^4.4.1",
    "qs": "^6.15.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "zod": "^4.3.6"
  }
}
