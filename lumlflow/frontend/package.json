    "@primevue/forms": "^4.3.9",
    "@tailwindcss/vite": "^4.1.18",
    "@vueuse/core": "^14.1.0",
    "axios": "^1.7.7",
    "lucide-vue-next": "^0.460.0",
    "pinia": "^2.2.6",
    "primevue": "^4.4.1",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8",
    "@luml/attachments": "*",
    "@luml/experiments": "*"
  }
