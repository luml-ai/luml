{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "../../extras/js/packages/experiments/src/**/*",
    "../../extras/js/packages/attachments/src/**/*"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "../../extras/js/packages/experiments/src/demo/**/*",
    "../../extras/js/packages/attachments/src/demo/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@luml/experiments": ["../../extras/js/packages/experiments/src/index.ts"],
      "@luml/attachments": ["../../extras/js/packages/attachments/src/index.ts"],
      "@experiments/*": ["../../extras/js/packages/experiments/src/*"],
      "@attachments/*": ["../../extras/js/packages/attachments/src/*"]
    }
  }
}
